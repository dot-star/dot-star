{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "editorMode": "vim",
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "command jq -r '.tool_response.filePath // .tool_input.file_path' | { read -r f; case \"$f\" in *.sh) chmod +x \"$f\" ;; esac; } 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      },
      {
        "hooks": [
          {
            "command": "${HOME}/.claude/hooks/worktree_marker.sh",
            "type": "command"
          }
        ],
        "matcher": "EnterWorktree|ExitWorktree"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "${HOME}/.claude/hooks/validate_bash_command.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "command jq -r '.session_id' | { read -r sid; sid=${sid//[^a-zA-Z0-9-]/}; dir=\"/tmp/claude/$sid\"; mkdir -p \"$dir\" && command jq -nc --arg dir \"$dir\" '{hookSpecificOutput:{hookEventName:\"SessionStart\",additionalContext:(\"Session-scoped tmp directory: \"+$dir+\" \\u2014 use this for any temporary files instead of /tmp directly.\")}}'; }",
            "type": "command"
          },
          {
            "command": "${HOME}/.claude/hooks/triage_nudge.sh",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "command jq -r '.last_assistant_message // empty' | head -c 100 | osascript -e 'on run' -e 'set msg to do shell script \"cat /dev/stdin\"' -e 'if msg is not \"\" then display notification msg with title \"Claude Code\"' -e 'end run'",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(bash -n *)",
      "Bash(chmod +x *)",
      "Bash(command -v jq)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr status *)",
      "Bash(gh pr view *)",
      "Bash(git --no-pager diff *)",
      "Bash(git --no-pager log *)",
      "Bash(git --no-pager show *)",
      "Bash(git add *)",
      "Bash(git diff *)",
      "Bash(git fetch *)",
      "Bash(git log *)",
      "Bash(git rev-list *)",
      "Bash(git show *)",
      "Bash(git status *)",
      "Bash(pbcopy)",
      "Bash(pbpaste)",
      "Edit(//tmp/claude/**)",
      "Read(//tmp/claude/**)",
      "Read(~/.claude/**)",
      "Read(~/.dot-star/ai/**)",
      "Read(~/Projects/dot-star/ai/**)",
      "Skill(worktree-done)",
      "Write(//tmp/claude/**)"
    ],
    "ask": [
      "Bash(gh api:*)"
    ],
    "deny": [
      "Bash(gh pr checkout:*)",
      "Bash(gh pr close:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr ready:*)",
      "Bash(gh pr reopen:*)",
      "Bash(gh pr review:*)",
      "Bash(gh pr update-branch:*)"
    ]
  },
  "statusLine": {
    "command": "${HOME}/.claude/hooks/statusline.sh",
    "type": "command"
  },
  "theme": "dark",
  "voice": {
    "enabled": true,
    "mode": "tap"
  },
  "voiceEnabled": true,
  "worktree": {
    "baseRef": "head"
  }
}
