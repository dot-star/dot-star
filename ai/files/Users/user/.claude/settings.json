{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "editorMode": "vim",
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "command jq -r '.tool_response.filePath // .tool_input.file_path' | { read -r f; case \"$f\" in *.sh) chmod +x \"$f\" ;; esac; } 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      },
      {
        "hooks": [
          {
            "command": "${HOME}/.claude/hooks/worktree_marker.sh",
            "type": "command"
          }
        ],
        "matcher": "EnterWorktree|ExitWorktree"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "${HOME}/.claude/hooks/validate_bash_command.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "command jq -r '.session_id' | { read -r sid; sid=${sid//[^a-zA-Z0-9-]/}; dir=\"/tmp/claude/$sid\"; mkdir -p \"$dir\" && command jq -nc --arg dir \"$dir\" '{hookSpecificOutput:{hookEventName:\"SessionStart\",additionalContext:(\"Session-scoped tmp directory: \"+$dir+\" \\u2014 use this for any temporary files instead of /tmp directly.\")}}'; }",
            "type": "command"
          },
          {
            "command": "${HOME}/.claude/hooks/triage_nudge.sh",
            "type": "command"
          },
          {
            "command": "${HOME}/.claude/hooks/load_claude_md_supplementals.sh",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "command jq -r '.last_assistant_message // empty' | head -c 100 | osascript -e 'on run' -e 'set msg to do shell script \"cat /dev/stdin\"' -e 'if msg is not \"\" then display notification msg with title \"Claude Code\"' -e 'end run'",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(bash -n *)",
      "Bash(brew list *)",
      "Bash(chmod +x *)",
      "Bash(command -v jq)",
      "Bash(echo \"branch: $\\(git symbolic-ref --short HEAD\\)\")",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr status *)",
      "Bash(gh pr view *)",
      "Bash(git --no-pager diff *)",
      "Bash(git --no-pager log *)",
      "Bash(git --no-pager show *)",
      "Bash(git add *)",
      "Bash(git diff *)",
      "Bash(git fetch *)",
      "Bash(git log *)",
      "Bash(git rebase *)",
      "Bash(git rev-list *)",
      "Bash(git show *)",
      "Bash(git stash list)",
      "Bash(git stash pop)",
      "Bash(git status *)",
      "Bash(git symbolic-ref *)",
      "Bash(git update-index *)",
      "Bash(git worktree *)",
      "Bash(pbcopy)",
      "Bash(pbpaste)",
      "Edit(//tmp/claude/**)",
      "Read(//Users/user/.claude/**)",
      "Read(//tmp/claude/**)",
      "Read(~/.claude/**)",
      "Read(~/.dot-star/ai/**)",
      "Read(~/.dot-star/bash/**)",
      "Read(~/.dot-star/bat/**)",
      "Read(~/.dot-star/brew/**)",
      "Read(~/.dot-star/coffeescript/**)",
      "Read(~/.dot-star/colordiff/**)",
      "Read(~/.dot-star/django/**)",
      "Read(~/.dot-star/docker/**)",
      "Read(~/.dot-star/glow/**)",
      "Read(~/.dot-star/lynx/**)",
      "Read(~/.dot-star/node/**)",
      "Read(~/.dot-star/php/**)",
      "Read(~/.dot-star/python/**)",
      "Read(~/.dot-star/quilt/**)",
      "Read(~/.dot-star/sass/**)",
      "Read(~/.dot-star/screen/**)",
      "Read(~/.dot-star/screenshots/**)",
      "Read(~/.dot-star/script/**)",
      "Read(~/.dot-star/ssh/**)",
      "Read(~/.dot-star/version_control/**)",
      "Read(~/.dot-star/vim/**)",
      "Read(~/.dot-star/virtualenv/**)",
      "Read(~/.dot-star/zsh/**)",
      "Read(~/Projects/dot-star/ai/**)",
      "Read(~/Projects/dot-star/bash/**)",
      "Read(~/Projects/dot-star/bat/**)",
      "Read(~/Projects/dot-star/brew/**)",
      "Read(~/Projects/dot-star/coffeescript/**)",
      "Read(~/Projects/dot-star/colordiff/**)",
      "Read(~/Projects/dot-star/django/**)",
      "Read(~/Projects/dot-star/docker/**)",
      "Read(~/Projects/dot-star/glow/**)",
      "Read(~/Projects/dot-star/lynx/**)",
      "Read(~/Projects/dot-star/node/**)",
      "Read(~/Projects/dot-star/php/**)",
      "Read(~/Projects/dot-star/python/**)",
      "Read(~/Projects/dot-star/quilt/**)",
      "Read(~/Projects/dot-star/sass/**)",
      "Read(~/Projects/dot-star/screen/**)",
      "Read(~/Projects/dot-star/screenshots/**)",
      "Read(~/Projects/dot-star/script/**)",
      "Read(~/Projects/dot-star/ssh/**)",
      "Read(~/Projects/dot-star/version_control/**)",
      "Read(~/Projects/dot-star/vim/**)",
      "Read(~/Projects/dot-star/virtualenv/**)",
      "Read(~/Projects/dot-star/zsh/**)",
      "Skill(codify)",
      "Skill(commit)",
      "Skill(triage-permissions)",
      "Skill(try)",
      "Skill(untry)",
      "Skill(update-config)",
      "Skill(worktree-done)",
      "Write(//tmp/claude/**)"
    ],
    "ask": [
      "Bash(gh api:*)",
      "Bash(git commit:*)"
    ],
    "deny": [
      "Bash(gh pr checkout:*)",
      "Bash(gh pr close:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr ready:*)",
      "Bash(gh pr reopen:*)",
      "Bash(gh pr review:*)",
      "Bash(gh pr update-branch:*)"
    ]
  },
  "statusLine": {
    "command": "${HOME}/.claude/hooks/statusline.sh",
    "type": "command"
  },
  "theme": "dark",
  "voice": {
    "enabled": true,
    "mode": "tap"
  },
  "voiceEnabled": true,
  "worktree": {
    "baseRef": "fresh"
  }
}
