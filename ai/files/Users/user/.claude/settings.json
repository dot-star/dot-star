{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "editorMode": "vim",
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "${HOME}/.claude/hooks/announce_window_state.py Notification",
            "type": "command"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "${HOME}/.claude/hooks/log_permission_requests.py",
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "${HOME}/.claude/hooks/enforce_executable_bit.sh",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      },
      {
        "hooks": [
          {
            "command": "${HOME}/.claude/hooks/worktree_marker.sh",
            "type": "command"
          }
        ],
        "matcher": "EnterWorktree|ExitWorktree"
      },
      {
        "hooks": [
          {
            "command": "${HOME}/.claude/hooks/recheck_amended_subject.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "${HOME}/.claude/hooks/announce_window_state.py PostToolUse",
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "${HOME}/.claude/hooks/validate_bash_command.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "${HOME}/.claude/hooks/remind_style_guide.sh",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "command jq -r '.session_id' | { read -r sid; sid=${sid//[^a-zA-Z0-9-]/}; dir=\"/tmp/claude/$sid\"; mkdir -p \"$dir\" && command jq -nc --arg dir \"$dir\" '{hookSpecificOutput:{hookEventName:\"SessionStart\",additionalContext:(\"Session-scoped tmp directory: \"+$dir+\" \\u2014 use this for any temporary files instead of /tmp directly.\")}}'; }",
            "type": "command"
          },
          {
            "command": "${HOME}/.claude/hooks/load_claude_md_supplementals.sh",
            "type": "command"
          },
          {
            "command": "${HOME}/.claude/hooks/announce_window_state.py SessionStart",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "command jq -r '.last_assistant_message // empty' | head -c 100 | osascript -e 'on run' -e 'set msg to do shell script \"cat /dev/stdin\"' -e 'if msg is not \"\" then display notification msg with title \"Claude Code\"' -e 'end run'",
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "${HOME}/.claude/hooks/check_bracket_prefix.sh",
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "${HOME}/.claude/hooks/check_acronyms.py",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash([ -s *)",
      "Bash(bash -n *)",
      "Bash(brew list *)",
      "Bash(chmod +x *)",
      "Bash(command -v jq)",
      "Bash(echo \"branch: $\\(git symbolic-ref --short HEAD\\)\")",
      "Bash(echo \"exit: $?\")",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr status *)",
      "Bash(gh pr view *)",
      "Bash(gh repo clone:*)",
      "Bash(gh run view *)",
      "Bash(git --no-pager diff *)",
      "Bash(git --no-pager log *)",
      "Bash(git --no-pager show *)",
      "Bash(git -C * checkout *)",
      "Bash(git -C * merge *)",
      "Bash(git -C * merge-base *)",
      "Bash(git -C * stash *)",
      "Bash(git -c color.ui=always diff)",
      "Bash(git add *)",
      "Bash(git diff *)",
      "Bash(git fetch *)",
      "Bash(git log *)",
      "Bash(git mv *)",
      "Bash(git rebase *)",
      "Bash(git rev-list *)",
      "Bash(git show *)",
      "Bash(git stash list)",
      "Bash(git stash pop)",
      "Bash(git status *)",
      "Bash(git symbolic-ref *)",
      "Bash(git update-index *)",
      "Bash(git worktree *)",
      "Bash(open https://github.com/*)",
      "Bash(pbcopy)",
      "Bash(pbpaste)",
      "Edit(//tmp/claude/**)",
      "Read(//Users/user/.claude/**)",
      "Read(//tmp/claude/**)",
      "Read(~/.claude/**)",
      "Read(~/.dot-star/ai/**)",
      "Read(~/.dot-star/screenshots/**)",
      "Read(~/.dot-star/script/**)",
      "Read(~/.dot-star/tools/bash/**)",
      "Read(~/.dot-star/tools/bat/**)",
      "Read(~/.dot-star/tools/brew/**)",
      "Read(~/.dot-star/tools/coffeescript/**)",
      "Read(~/.dot-star/tools/colordiff/**)",
      "Read(~/.dot-star/tools/django/**)",
      "Read(~/.dot-star/tools/docker/**)",
      "Read(~/.dot-star/tools/glow/**)",
      "Read(~/.dot-star/tools/lynx/**)",
      "Read(~/.dot-star/tools/node/**)",
      "Read(~/.dot-star/tools/php/**)",
      "Read(~/.dot-star/tools/python/**)",
      "Read(~/.dot-star/tools/quilt/**)",
      "Read(~/.dot-star/tools/sass/**)",
      "Read(~/.dot-star/tools/screen/**)",
      "Read(~/.dot-star/tools/ssh/**)",
      "Read(~/.dot-star/tools/version_control/**)",
      "Read(~/.dot-star/tools/vim/**)",
      "Read(~/.dot-star/tools/virtualenv/**)",
      "Read(~/.dot-star/tools/zsh/**)",
      "Read(~/Projects/dot-star/ai/**)",
      "Read(~/Projects/dot-star/screenshots/**)",
      "Read(~/Projects/dot-star/script/**)",
      "Read(~/Projects/dot-star/tools/bash/**)",
      "Read(~/Projects/dot-star/tools/bat/**)",
      "Read(~/Projects/dot-star/tools/brew/**)",
      "Read(~/Projects/dot-star/tools/coffeescript/**)",
      "Read(~/Projects/dot-star/tools/colordiff/**)",
      "Read(~/Projects/dot-star/tools/django/**)",
      "Read(~/Projects/dot-star/tools/docker/**)",
      "Read(~/Projects/dot-star/tools/glow/**)",
      "Read(~/Projects/dot-star/tools/lynx/**)",
      "Read(~/Projects/dot-star/tools/node/**)",
      "Read(~/Projects/dot-star/tools/php/**)",
      "Read(~/Projects/dot-star/tools/python/**)",
      "Read(~/Projects/dot-star/tools/quilt/**)",
      "Read(~/Projects/dot-star/tools/sass/**)",
      "Read(~/Projects/dot-star/tools/screen/**)",
      "Read(~/Projects/dot-star/tools/ssh/**)",
      "Read(~/Projects/dot-star/tools/version_control/**)",
      "Read(~/Projects/dot-star/tools/vim/**)",
      "Read(~/Projects/dot-star/tools/virtualenv/**)",
      "Read(~/Projects/dot-star/tools/zsh/**)",
      "Skill(codify)",
      "Skill(commit)",
      "Skill(try)",
      "Skill(untry)",
      "Skill(update-config)",
      "Skill(worktree-done)",
      "WebFetch(domain:status.anthropic.com)",
      "WebFetch(domain:status.claude.com)",
      "Write(//tmp/claude/**)"
    ],
    "ask": [
      "Bash(gh api:*)",
      "Bash(gh pr checkout:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr edit:*)",
      "Bash(git commit:*)"
    ],
    "deny": [
      "Bash(gh pr close:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr ready:*)",
      "Bash(gh pr reopen:*)",
      "Bash(gh pr review:*)",
      "Bash(gh pr update-branch:*)"
    ]
  },
  "statusLine": {
    "command": "${HOME}/.claude/hooks/statusline.sh",
    "type": "command"
  },
  "theme": "dark",
  "voice": {
    "enabled": true,
    "mode": "tap"
  },
  "voiceEnabled": true,
  "worktree": {
    "baseRef": "fresh"
  }
}
